# Environment Variables
# Copy this to .env and fill in real values
#
# ⚠️  NEVER commit .env to git — only commit .env.example

# Anthropic API key (server-side ONLY)
ANTHROPIC_API_KEY=sk-ant-...

CLAW_MODEL=your-value-here

CLAW_PROVIDER=your-value-here

CLAW_QUALITY_GATE=your-value-here

CLAW_REFLECTION=your-value-here

CLAW_SCAFFOLD_TIMEOUT=your-value-here

CLAW_SMALL_MODEL=your-value-here

CLAW_THINKING=your-value-here

CLAW_TIMEOUT=your-value-here

CLAW_VISION_MODEL=your-value-here

CLAW_WIRING=your-value-here

DASHSCOPE_API_KEY=your-value-here

DASHSCOPE_COOLDOWN=your-value-here

NEXT_PUBLIC_APP_URL=your-value-here

# Supabase anonymous key (client-safe) (client-safe)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase project URL (client-safe)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co

OLLAMA_HOST=your-value-here

# OpenAI API key (server-side ONLY)
OPENAI_API_KEY=sk-...

OPENROUTER_API_KEY=your-value-here

SECRET=your-value-here

# Stripe secret key (server-side only) (server-side ONLY)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook endpoint secret (server-side ONLY)
STRIPE_WEBHOOK_SECRET=whsec_...

VAR=your-value-here

VAR_NAME=your-value-here

VITE_=your-value-here

X=your-value-here

SUPABASE_SERVICE_ROLE_KEY=
